# Copy this file to .env and fill in the values.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/viral_news

# Reddit OAuth app credentials  (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_SECRET=your_reddit_secret
REDDIT_USER_AGENT=viral-news-bot/1.0 (by /u/your_username)

# Scheduler – how often to run the ingestion pipeline (minutes)
FETCH_INTERVAL_MINUTES=10

# Minimum virality score for an article to be stored
VIRALITY_THRESHOLD=7.0

# How many Reddit posts to pull per subreddit per run
REDDIT_POST_LIMIT=25

# ---------------------------------------------------------------------------
# Lovable frontend integration
# ---------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins.
# Set to your Lovable project URL in production:
#   CORS_ORIGINS=https://your-project.lovable.app
# Leave as * for local development only.
CORS_ORIGINS=*

# The public URL where this API is deployed (used in OpenAPI docs).
# Set this when you deploy to Railway / Render / Fly.io.
API_BASE_URL=https://your-backend.railway.app
